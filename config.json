{
  "language": "en",
  "file_categories": {
    "images": {
      "description": "Image files",
      "extensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tiff", ".webp", ".svg", ".ico", ".raw", ".heic"]
    },
    "videos": {
      "description": "Video files",
      "extensions": [".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".mpg", ".mpeg", ".3gp"]
    },
    "audios": {
      "description": "Audio files",
      "extensions": [".mp3", ".wav", ".flac", ".aac", ".m4a", ".ogg", ".wma", ".ape", ".alac"]
    },
    "documents": {
      "description": "Document files",
      "extensions": [".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".txt", ".md", ".rtf", ".csv"]
    },
    "archives": {
      "description": "Archive files",
      "extensions": [".zip", ".rar", ".7z", ".tar", ".gz", ".bz2", ".xz", ".tgz", ".rar5"]
    },
    "executables": {
      "description": "Executable and script files",
      "extensions": [".exe", ".msi", ".bat", ".sh", ".cmd", ".ps1"]
    },
    "code": {
      "description": "Source code files",
      "extensions": [".py", ".java", ".cpp", ".c", ".js", ".html", ".css", ".php", ".sql", ".go", ".rs", ".swift"]
    },
    "others": {
      "description": "Other files",
      "extensions": []
    }
  },
  "settings": {
    "default_mode": "copy",
    "rename_separator": "_",
    "include_hidden_files": false,
    "log_level": "verbose"
  }
}
